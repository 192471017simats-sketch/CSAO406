#include <stdio.h>

#define MAX 5

int queue[MAX];
int front = -1, rear = -1;

void enqueue(int p) {
    if (rear == MAX - 1)
        printf("Ready Queue is Full\n");
    else {
        if (front == -1)
            front = 0;
        rear++;
        queue[rear] = p;
        printf("Process P%d added.\n", p);
    }
}

void dequeue() {
    if (front == -1 || front > rear)
        printf("Ready Queue is Empty\n");
    else {
        printf("Executing Process P%d\n", queue[front]);
        front++;
    }
}

void display() {
    if (front == -1 || front > rear)
        printf("Ready Queue is Empty\n");
    else {
        int i;
        printf("Ready Queue: ");
        for (i = front; i <= rear; i++)
            printf("P%d ", queue[i]);
        printf("\n");
    }
}

int main() {
    int choice, p;

    do {
        printf("\n--- Ready Queue Simulation ---\n");
        printf("1. Add Process\n");
        printf("2. Execute Process\n");
        printf("3. Display Ready Queue\n");
        printf("4. Exit\n");
        printf("Enter Choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                printf("Enter Process Number: ");
                scanf("%d", &p);
                enqueue(p);
                break;

            case 2:
                dequeue();
                break;

            case 3:
                display();
                break;

            case 4:
                printf("Exiting...\n");
                break;

            default:
                printf("Invalid Choice!\n");
        }
    } while (choice != 4);

    return 0;
}
