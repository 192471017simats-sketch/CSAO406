#include <stdio.h>
#include <unistd.h>
#include <sys/types.h>

int main() {
    pid_t pid1, pid2;

    pid1 = fork();  // Create first child
    if (pid1 < 0) {
        perror("fork failed");
        return 1;
    } 
    if (pid1 == 0) {
        // First child process
        printf("First child process ID: %d\n", getpid());
        return 0;
    } 

    pid2 = fork();  // Create second child
    if (pid2 < 0) {
        perror("fork failed");
        return 1;
    }
    if (pid2 == 0) {
        // Second child process
        printf("Second child process ID: %d\n", getpid());
        return 0;
    }

    // Parent process
    printf("Parent process ID: %d\n", getpid());

    return 0;
}
