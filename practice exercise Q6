#include <stdio.h>

int main() {
    int page[5] = {1, 2, 3, 2, 4};
    int frame[3] = {-1, -1, -1};
    int i, j, hit, pos = 0, faults = 0;

    for(i = 0; i < 5; i++) {
        hit = 0;
        for(j = 0; j < 3; j++)
            if(frame[j] == page[i]) hit = 1;

        if(!hit) {
            frame[pos] = page[i];
            pos = (pos + 1) % 3;
            faults++;
        }
    }

    printf("Page Faults = %d", faults);

    return 0;
}
